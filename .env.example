# Copy to `.env` and fill with REAL values locally.
# `.env` is git-ignored. NEVER put real secrets in this file (.env.example is committed).
# Document every environment variable the app needs here, with placeholder values.

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Database ---
DATABASE_URL=postgres://user:password@localhost:5432/gymhelper

# --- Auth / sessions (generate strong random values locally) ---
JWT_SECRET=replace-with-a-long-random-string
SESSION_SECRET=replace-with-a-long-random-string