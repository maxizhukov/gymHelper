# Copy to `.env` and fill with REAL values locally.
# `.env` is git-ignored. NEVER put real secrets in this file (.env.example is committed).
# Document every environment variable the app needs here, with placeholder values.

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Database ---
DATABASE_URL=postgres://user:password@localhost:5432/gymhelper

# --- Auth / sessions (generate strong random values locally) ---
JWT_SECRET=replace-with-a-long-random-string
SESSION_SECRET=replace-with-a-long-random-string

# --- Deploy notifications (Telegram) ---
# Bot token from @BotFather and the target chat/channel id the bot posts to.
TELEGRAM_BOT_TOKEN=123456:replace-with-bot-token-from-botfather
TELEGRAM_CHAT_ID=-1000000000000
# Shared secret the CI deploy webhook must send in the X-Deploy-Secret header.
# Store the same value as the DEPLOY_WEBHOOK_SECRET GitHub Actions secret.
DEPLOY_WEBHOOK_SECRET=replace-with-a-long-random-string

# --- OpenAI (food parsing) ---
# Server-side only. Used by the backend to call the OpenAI API; it is never
# exposed to the frontend. Create one at https://platform.openai.com/api-keys.
OPENAI_API_KEY=sk-replace-with-your-openai-api-key