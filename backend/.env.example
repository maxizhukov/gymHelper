# Copy to `.env` for local development. `.env` is git-ignored — never commit real values.

# PostgreSQL connection string.
# - Production: injected on the server from /opt/gymhelper/.env; host is `postgres`
#   (the shared Docker network), e.g. postgres://gymhelper:***@postgres:5432/gymhelper
# - Local dev against the server DB: open an SSH tunnel and point at localhost:
#     ssh -N -L 5433:localhost:5432 root@165.227.137.141
#   then use host localhost:5433 below.
DATABASE_URL=postgres://gymhelper:password@localhost:5433/gymhelper

# Server-side OpenAI key for food parsing. Never exposed to the frontend.
OPENAI_API_KEY=sk-replace-with-your-openai-api-key
